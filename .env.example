# Clerk (https://dashboard.clerk.com) — copy to `.env.local` for Next.js
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Optional: FastAPI base URL when you call the workspace API from the browser or server routes
NEXT_PUBLIC_API_URL=http://localhost:8787
