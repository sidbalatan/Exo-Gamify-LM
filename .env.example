# Clerk (https://dashboard.clerk.com) — copy to `.env.local` for Next.js
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# FastAPI workspace API (browser + Clerk components can read the public fallback)
NEXT_PUBLIC_API_URL=http://localhost:8787

# Prefer this for `/api/workspace/*` server proxy (omit to reuse NEXT_PUBLIC_API_URL)
WORKSPACE_API_URL=http://localhost:8787
