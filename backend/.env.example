# Copy to `backend/.env` and fill values from the Clerk Dashboard (API keys → JWKS).
CLERK_JWKS_URL=https://YOUR_FRONTEND_DOMAIN.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://YOUR_FRONTEND_DOMAIN.clerk.accounts.dev
# Optional: set if you validate audience (recommended for backends with auth templates)
CLERK_AUDIENCE=

# Comma-separated browser origins hitting this API locally
CORS_ORIGINS=http://localhost:3000

# Postgres (asyncpg pool) — required for `/v1/workspace/me` + `/targets`
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/xquest

# ExoReg: distinct users needed on winning vote side (default 1 if unset in app)
EXOREG_CONSENSUS_MIN_VOTES=1

# Writable directory for user file blobs (images, CSV, PDF, …). API must create this or parents.
WORKSPACE_BLOB_ROOT=./data/blob
