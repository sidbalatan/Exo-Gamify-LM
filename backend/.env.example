# Copy to `backend/.env` and fill values from the Clerk Dashboard (API keys → JWKS).
CLERK_JWKS_URL=https://YOUR_FRONTEND_DOMAIN.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://YOUR_FRONTEND_DOMAIN.clerk.accounts.dev
# Optional: set if you validate audience (recommended for backends with auth templates)
CLERK_AUDIENCE=

# Comma-separated browser origins hitting this API locally
CORS_ORIGINS=http://localhost:3000

# Uncomment when attaching asyncpg
# DATABASE_URL=postgresql://user:pass@localhost:5432/xquest
